{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "IDX Terminal",
  "version": "0.1.0",
  "identifier": "com.idxterminal.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "IDX Terminal",
        "width": 1440,
        "height": 900,
        "minWidth": 1100,
        "minHeight": 700,
        "decorations": true,
        "transparent": false,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "msi"
    ],
    "icon": [
      "icons/icon.ico"
    ]
  }
}
